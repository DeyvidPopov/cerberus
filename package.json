{
  "name": "cerberus",
  "version": "0.0.0",
  "private": true,
  "description": "Cerberus — a zero-knowledge password vault with adaptive, risk-based authentication.",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "migrations"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "build": "npm run build --workspaces --if-present",
    "migrate": "npm run migrate --workspace @cerberus/migrations",
    "dev:server": "npm run dev --workspace @cerberus/server",
    "dev:desktop": "npm run dev --workspace @cerberus/desktop",
    "dev:app": "npm run tauri:dev --workspace @cerberus/desktop",
    "build:cli": "cargo build --bin cerberus-cli --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "demo:seed": "npm run demo:seed --workspace @cerberus/server",
    "demo:reset": "npm run demo:reset --workspace @cerberus/server",
    "demo:impostor": "npm run demo:impostor --workspace @cerberus/server"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
