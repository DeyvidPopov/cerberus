{
  "name": "@cerberus/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cerberus API server (Express + TypeScript). Layered: routes → services → repositories.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "eval:keystroke": "tsx src/eval/run-keystroke-eval.ts"
  },
  "dependencies": {
    "@cerberus/protocol": "*",
    "@cerberus/shared-types": "*",
    "@node-rs/argon2": "^2.0.2",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0"
  }
}
