{
  "name": "@cerberus/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cerberus API server (Express + TypeScript). Layered: routes → services → repositories.",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "start": "tsx --env-file-if-exists=../../.env src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "eval:keystroke": "tsx src/eval/run-keystroke-eval.ts",
    "eval:mouse": "tsx src/eval/run-mouse-eval.ts",
    "eval:tune": "tsx src/eval/run-threshold-tuning.ts",
    "eval:integrated": "tsx src/eval/run-integrated-analysis.ts",
    "demo:seed": "tsx --env-file-if-exists=../../.env src/demo/seed.ts",
    "demo:reset": "tsx --env-file-if-exists=../../.env src/demo/reset.ts",
    "demo:impostor": "tsx --env-file-if-exists=../../.env src/demo/impostor.ts"
  },
  "dependencies": {
    "@cerberus/protocol": "*",
    "@cerberus/shared-types": "*",
    "@node-rs/argon2": "^2.0.2",
    "express": "^4.21.2",
    "maxmind": "^4.3.27",
    "pg": "^8.13.1",
    "ws": "^8.21.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.18.1",
    "supertest": "^7.0.0"
  }
}
