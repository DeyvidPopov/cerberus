# ---------------------------------------------------------------------------
# Secrets — NEVER commit (PROJECT.md §1, §7; threat-model.md).
# Only .env.example (which contains no real values) is tracked.
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.keystore
secrets/
keys/

# ---------------------------------------------------------------------------
# Dependencies
# ---------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js

# ---------------------------------------------------------------------------
# Build artifacts
# ---------------------------------------------------------------------------
dist/
build/
out/
coverage/
*.tsbuildinfo

# Rust / Cargo
target/
**/*.rs.bk

# Tauri generated output
apps/desktop/src-tauri/gen/
apps/desktop/src-tauri/target/

# Vite
.vite/

# ---------------------------------------------------------------------------
# Evaluation datasets — real human keystroke captures (PROJECT.md §5).
# NEVER commit the raw dataset. Only committed scripts + derived RESULTS are
# tracked; the dataset is fetched locally into this gitignored dir (ADR-0010).
# ---------------------------------------------------------------------------
docs/evaluation/data/

# ---------------------------------------------------------------------------
# Offline GeoIP database (ADR-0011). Fetched locally, never committed (licensing
# + size). The geovelocity signal degrades to neutral when it is absent.
# ---------------------------------------------------------------------------
*.mmdb
apps/server/data/

# ---------------------------------------------------------------------------
# Design reference mockup (M12 / ADR-0015). The visual target for the UI restyle;
# it is NOT imported by the app and is never shipped/bundled. Kept locally only.
# ---------------------------------------------------------------------------
/design/

